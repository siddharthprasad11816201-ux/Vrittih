# =============================================
# VRITTIH — ENVIRONMENT TEMPLATE
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# =============================================

# Database — SQLite for dev; Postgres connection string for production
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/vrittih"

# Auth — in-house HS256 JWT. Generate: openssl rand -hex 48
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRY="7d"

# App URLs
NEXT_PUBLIC_APP_URL="http://localhost:3002"
APP_URL="http://localhost:3002"
NODE_ENV="development"

# Realtime endpoints — in prod point these at your wss:// chat + signaling hosts.
# Leave blank in dev (falls back to ws://localhost:3001 and http://localhost:3002).
NEXT_PUBLIC_WS_URL=""
NEXT_PUBLIC_SIGNAL_URL=""

# Face-vector encryption key — must be exactly 32 characters
FACE_VECTOR_KEY="change-me-to-a-32-character-key!"

# In-house SMTP relay (outbound email). Leave blank in dev to skip sending.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
MAIL_EHLO="vrittih.online"

# Payments (optional; gateway is pluggable)
ACTIVE_PAYMENT_GATEWAY=""
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Background worker
WORKER_SECRET="change-me"
WORKER_INTERVAL_MS="15000"

# Super admin bootstrap (used by `node prisma/seed-admin.mjs`)
SUPERADMIN_EMAIL="superadmin@vrittih.online"
SUPERADMIN_PASSWORD="change-me"
SUPERADMIN_NAME="Super Admin"

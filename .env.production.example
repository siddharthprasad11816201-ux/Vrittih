# =============================================================================
# VRITTIH — PRODUCTION ENVIRONMENT
# Set these in your HOST's env (Railway/Render/Vercel/Neon), NOT in a committed
# file. [REQUIRED] must be set or the app will not run correctly; [optional]
# enables an extra capability. Generate secrets with:  openssl rand -hex 48
# =============================================================================

# --- Database ---------------------------------------------------------------
# [REQUIRED] Your Postgres connection string (Neon/Railway/Supabase/RDS).
# Must start with postgresql:// . Keep sslmode=require for managed Postgres.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth (in-house HS256 JWT) ---------------------------------------------
# [REQUIRED] Long random secret. The app REFUSES to start in production if this
# is unset or left at the dev default (forged-token protection).
JWT_SECRET="set-a-64-char-random-hex-secret"
JWT_EXPIRY="7d"                                    # [optional]

# --- App identity -----------------------------------------------------------
NODE_ENV="production"                              # [REQUIRED] must be "production"
NEXT_PUBLIC_APP_URL="https://vrittih.online"       # [REQUIRED] your public URL
APP_URL="https://vrittih.online"                   # [REQUIRED] same, server-side

# --- Face verification key --------------------------------------------------
# [REQUIRED if using face login/enrollment] EXACTLY 32 characters. The app
# refuses to start in production if unset/left at the dev default (protects
# biometric templates). Not using face features? You can still set any 32 chars.
FACE_VECTOR_KEY="a-32-character-production-key!!!"

# --- Payments (Razorpay) ----------------------------------------------------
# [REQUIRED for paid plans] Keys from dashboard.razorpay.com → Settings → API.
# Price shows in CHF, charged in the customer's currency at the live ECB rate.
# Non-INR currencies need "International Payments" enabled on the account.
ACTIVE_PAYMENT_GATEWAY="razorpay"
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxx"   # same as RAZORPAY_KEY_ID (client checkout)

# --- Super admin bootstrap (used by `npm run seed:admin`) -------------------
# [REQUIRED] Set a REAL password here before seeding — do not ship "change-me".
SUPERADMIN_EMAIL="superadmin@vrittih.online"
SUPERADMIN_PASSWORD="set-a-strong-password"
SUPERADMIN_NAME="Super Admin"

# --- Background worker ------------------------------------------------------
# [REQUIRED if running server/worker.js] Shared secret the worker sends to
# /api/internal/jobs/tick. Without a worker, the queue drains on-request.
WORKER_SECRET="set-a-random-worker-secret"
WORKER_INTERVAL_MS="15000"                         # [optional]

# --- Realtime chat & video interviews --------------------------------------
# [optional] Point at your wss:// chat host and https:// WebRTC signaling host.
# Leave blank to disable live chat/interview rooms (the rest of the app is fine).
NEXT_PUBLIC_WS_URL=""
NEXT_PUBLIC_SIGNAL_URL=""

# --- Outbound email (in-house SMTP relay) ----------------------------------
# [optional] For transactional mail. Leave blank to skip sending.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
MAIL_EHLO="vrittih.online"
